# ── Telegram ────────────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram
TELEGRAM_TOKEN=your-bot-token-here

# Your personal chat ID — send a message to @userinfobot to find it
TELEGRAM_CHAT_ID=123456789

# ── Optional: CAPTCHA solving service ───────────────────────────────────────
# Supported: 2captcha, capsolver
# Leave blank to disable (captcha solving will not be attempted)
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=

# ── Paths (defaults shown, override if needed) ───────────────────────────────
# WATCHERS_CONFIG=config/watchers.yaml
# DB_PATH=storage/state.db
# SESSIONS_DIR=storage/sessions
